const express = require('express');
const router = express.Router();
const db = require('../database');
const { auth, optionalAuth } = require('../middleware/auth');
const { body, validationResult } = require('express-validator');

// Get all projects
router.get('/', optionalAuth, (req, res) => {
  try {
    const { status, tags, search, page = 1, limit = 20 } = req.query;
    const offset = (page - 1) * limit;

    let query = `
      SELECT p.*, u.nickname as creator_name, u.avatar as creator_avatar, u.school as creator_school
      FROM projects p
      JOIN users u ON p.creator_id = u.id
      WHERE 1=1
    `;
    const params = [];

    if (status) {
      query += ' AND p.status = ?';
      params.push(status);
    }
    if (search) {
      query += ' AND (p.title LIKE ? OR p.description LIKE ?)';
      params.push(`%${search}%`, `%${search}%`);
    }

    query += ' ORDER BY p.created_at DESC LIMIT ? OFFSET ?';
    params.push(parseInt(limit), offset);

    const projects = db.prepare(query).all(...params);

    // Parse JSON fields
    projects.forEach(project => {
      if (project.tags) project.tags = JSON.parse(project.tags);
      if (project.required_skills) project.required_skills = JSON.parse(project.required_skills);
      if (project.required_roles) project.required_roles = JSON.parse(project.required_roles);
    });

    res.json({ projects, page: parseInt(page), limit: parseInt(limit) });
  } catch (error) {
    console.error('Get projects error:', error);
    res.status(500).json({ error: 'Failed to get projects' });
  }
});

// Get single project
router.get('/:id', optionalAuth, (req, res) => {
  try {
    const project = db.prepare(`
      SELECT p.*, u.nickname as creator_name, u.avatar as creator_avatar, u.school as creator_school, u.major as creator_major
      FROM projects p
      JOIN users u ON p.creator_id = u.id
      WHERE p.id = ?
    `).get(req.params.id);

    if (!project) {
      return res.status(404).json({ error: 'Project not found' });
    }

    // Parse JSON fields
    if (project.tags) project.tags = JSON.parse(project.tags);
    if (project.required_skills) project.required_skills = JSON.parse(project.required_skills);
    if (project.required_roles) project.required_roles = JSON.parse(project.required_roles);

    // Get members
    const members = db.prepare(`
      SELECT pm.*, u.nickname, u.avatar, u.school, u.major, u.tags as user_tags
      FROM project_members pm
      JOIN users u ON pm.user_id = u.id
      WHERE pm.project_id = ?
    `).all(req.params.id);

    members.forEach(member => {
      if (member.user_tags) member.user_tags = JSON.parse(member.user_tags);
    });

    // Get applications
    const applications = db.prepare(`
      SELECT pa.*, u.nickname, u.avatar, u.school, u.major
      FROM project_applications pa
      JOIN users u ON pa.user_id = u.id
      WHERE pa.project_id = ?
    `).all(req.params.id);

    // Check if user has applied
    let hasApplied = false;
    let isMember = false;
    if (req.user) {
      const application = db.prepare('SELECT * FROM project_applications WHERE project_id = ? AND user_id = ?').get(req.params.id, req.user.id);
      hasApplied = !!application;

      const membership = db.prepare('SELECT * FROM project_members WHERE project_id = ? AND user_id = ?').get(req.params.id, req.user.id);
      isMember = !!membership;
    }

    res.json({ project, members, applications, hasApplied, isMember });
  } catch (error) {
    console.error('Get project error:', error);
    res.status(500).json({ error: 'Failed to get project' });
  }
});

// Create project
router.post('/', auth, [
  body('title').notEmpty().withMessage('Title is required'),
  body('description').notEmpty().withMessage('Description is required'),
], async (req, res) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      return res.status(400).json({ errors: errors.array() });
    }

    const { title, description, required_skills, required_roles, max_members, deadline, tags } = req.body;

    const result = db.prepare(`
      INSERT INTO projects (title, description, required_skills, required_roles, creator_id, max_members, deadline, tags)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `).run(title, description, required_skills ? JSON.stringify(required_skills) : null, required_roles ? JSON.stringify(required_roles) : null, req.user.id, max_members, deadline, tags ? JSON.stringify(tags) : null);

    // Add creator as member
    db.prepare(`
      INSERT INTO project_members (project_id, user_id, role)
      VALUES (?, ?, 'creator')
    `).run(result.lastInsertRowid, req.user.id);

    const project = db.prepare('SELECT * FROM projects WHERE id = ?').get(result.lastInsertRowid);

    res.status(201).json({ message: 'Project created successfully', project });
  } catch (error) {
    console.error('Create project error:', error);
    res.status(500).json({ error: 'Failed to create project' });
  }
});

// Apply for project
router.post('/:id/apply', auth, [
  body('message').notEmpty().withMessage('Message is required'),
], async (req, res) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      return res.status(400).json({ errors: errors.array() });
    }

    const project = db.prepare('SELECT * FROM projects WHERE id = ?').get(req.params.id);

    if (!project) {
      return res.status(404).json({ error: 'Project not found' });
    }

    if (project.status !== 'recruiting') {
      return res.status(400).json({ error: 'Project is not recruiting' });
    }

    if (project.creator_id === req.user.id) {
      return res.status(400).json({ error: 'Cannot apply to your own project' });
    }

    // Check if already applied or member
    const existing = db.prepare('SELECT * FROM project_applications WHERE project_id = ? AND user_id = ?').get(req.params.id, req.user.id);
    if (existing) {
      return res.status(400).json({ error: 'Already applied' });
    }

    const member = db.prepare('SELECT * FROM project_members WHERE project_id = ? AND user_id = ?').get(req.params.id, req.user.id);
    if (member) {
      return res.status(400).json({ error: 'Already a member' });
    }

    const { role, message } = req.body;

    db.prepare(`
      INSERT INTO project_applications (project_id, user_id, role, message)
      VALUES (?, ?, ?, ?)
    `).run(req.params.id, req.user.id, role, message);

    res.json({ message: 'Application submitted successfully' });
  } catch (error) {
    console.error('Apply for project error:', error);
    res.status(500).json({ error: 'Failed to submit application' });
  }
});

// Accept application
router.post('/:projectId/applications/:applicationId/accept', auth, (req, res) => {
  try {
    const project = db.prepare('SELECT * FROM projects WHERE id = ?').get(req.params.projectId);

    if (!project) {
      return res.status(404).json({ error: 'Project not found' });
    }

    if (project.creator_id !== req.user.id) {
      return res.status(403).json({ error: 'Only project creator can accept applications' });
    }

    const application = db.prepare('SELECT * FROM project_applications WHERE id = ? AND project_id = ?').get(req.params.applicationId, req.params.projectId);

    if (!application) {
      return res.status(404).json({ error: 'Application not found' });
    }

    // Check if project is full
    if (project.max_members && project.current_members >= project.max_members) {
      return res.status(400).json({ error: 'Project is full' });
    }

    // Add as member
    db.prepare(`
      INSERT INTO project_members (project_id, user_id, role)
      VALUES (?, ?, ?)
    `).run(req.params.projectId, application.user_id, application.role);

    // Update application status
    db.prepare('UPDATE project_applications SET status = "accepted" WHERE id = ?').run(req.params.applicationId);

    // Update project member count
    db.prepare('UPDATE projects SET current_members = current_members + 1 WHERE id = ?').run(req.params.projectId);

    res.json({ message: 'Application accepted successfully' });
  } catch (error) {
    console.error('Accept application error:', error);
    res.status(500).json({ error: 'Failed to accept application' });
  }
});

// Reject application
router.post('/:projectId/applications/:applicationId/reject', auth, (req, res) => {
  try {
    const project = db.prepare('SELECT * FROM projects WHERE id = ?').get(req.params.projectId);

    if (!project) {
      return res.status(404).json({ error: 'Project not found' });
    }

    if (project.creator_id !== req.user.id) {
      return res.status(403).json({ error: 'Only project creator can reject applications' });
    }

    db.prepare('UPDATE project_applications SET status = "rejected" WHERE id = ?').run(req.params.applicationId);

    res.json({ message: 'Application rejected successfully' });
  } catch (error) {
    console.error('Reject application error:', error);
    res.status(500).json({ error: 'Failed to reject application' });
  }
});

// Get my projects
router.get('/my/projects', auth, (req, res) => {
  try {
    const { status } = req.query;

    let query = `
      SELECT p.*, u.nickname as creator_name,
             CASE WHEN pm.role = 'creator' THEN 'creator' ELSE 'member' END as my_role
      FROM projects p
      JOIN users u ON p.creator_id = u.id
      JOIN project_members pm ON p.id = pm.project_id
      WHERE pm.user_id = ?
    `;
    const params = [req.user.id];

    if (status) {
      query += ' AND p.status = ?';
      params.push(status);
    }

    query += ' ORDER BY p.created_at DESC';

    const projects = db.prepare(query).all(...params);

    // Parse JSON fields
    projects.forEach(project => {
      if (project.tags) project.tags = JSON.parse(project.tags);
      if (project.required_skills) project.required_skills = JSON.parse(project.required_skills);
      if (project.required_roles) project.required_roles = JSON.parse(project.required_roles);
    });

    res.json({ projects });
  } catch (error) {
    console.error('Get my projects error:', error);
    res.status(500).json({ error: 'Failed to get projects' });
  }
});

module.exports = router;
